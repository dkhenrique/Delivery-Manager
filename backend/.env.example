# Banco de Dados (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=condominio
DB_PASS=condominio
DB_NAME=deliverymanager

# Servidor
PORT=3000

# JWT — OBRIGATÓRIO: gere uma chave segura para produção
JWT_SECRET=your_jwt_secret_here

# Mail Config (SMTP)
# Se não preenchido, o sistema utilizará o Ethereal (modo de teste) com URL no console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@deliverymanager.com
